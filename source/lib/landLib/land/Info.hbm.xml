<hibernate-mapping package="land">
 <class name="EnterTip" table="land_entertip">
  <id name="id">
   <generator class="increment"/>
  </id>
  <property generated="never" lazy="false" name="landId" not-null="true" unique="true"/>
  <property generated="never" lazy="false" name="tip"/>
 </class>
 <class name="LeaveTip" table="land_leavetip">
  <id name="id">
   <generator class="increment"/>
  </id>
  <property generated="never" lazy="false" name="landId" not-null="true" unique="true"/>
  <property generated="never" lazy="false" name="tip"/>
 </class>
 <class name="LandUser" table="land_landuser">
  <id name="id">
   <generator class="increment"/>
  </id>
  <property generated="never" lazy="false" name="name" not-null="true" unique="true"/>
  <property generated="never" lazy="false" name="maxLands" not-null="true"/>
 </class>
 <class name="Land" table="land_land">
  <id name="id">
   <generator class="increment"/>
  </id>
  <property name="fix"/>
  <property generated="never" lazy="false" name="type"/>
  <property generated="never" lazy="false" name="name"/>
  <property generated="never" lazy="false" name="overlap"/>
  <property name="price"/>
  <property generated="never" lazy="false" name="owner"/>
  <property column="range_" generated="never" lazy="false" name="range"/>
  <property generated="never" lazy="false" name="level"/>
  <property generated="never" lazy="false" name="friendPer"/>
  <property generated="never" lazy="false" name="flags" type="serializable"/>
  <property generated="never" lazy="false" name="pers" type="serializable"/>
 </class>
 <class name="LandSpawn" table="land_landspawn">
  <id name="id">
   <generator class="increment"/>
  </id>
  <property generated="never" lazy="false" name="landId" not-null="true" unique="true"/>
  <property generated="never" lazy="false" name="spawn"/>
  <property generated="never" lazy="false" name="yaw"/>
  <property generated="never" lazy="false" name="pitch"/>
 </class>
 <class name="LandCmd" table="land_landcmd">
  <id name="id">
   <generator class="increment"/>
  </id>
  <property generated="never" lazy="false" name="landId" not-null="true" unique="true"/>
  <property generated="never" lazy="false" name="cmd"/>
 </class>
</hibernate-mapping>
