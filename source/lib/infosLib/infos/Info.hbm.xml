<hibernate-mapping package="infos">
 <class name="PlayerDayInfo" table="infos_playerdayinfo">
  <id name="id">
   <generator class="increment"/>
  </id>
  <property generated="never" lazy="false" name="name"/>
  <property generated="never" lazy="false" name="time"/>
  <property generated="never" lazy="false" name="onlineTime"/>
 </class>
 <class name="PlayerInfo" table="infos_playerinfo">
  <id name="id">
   <generator class="increment"/>
  </id>
  <property generated="never" lazy="false" name="name"/>
  <property generated="never" lazy="false" name="joinTime"/>
  <property generated="never" lazy="false" name="lastTime"/>
  <property generated="never" lazy="false" name="alive"/>
  <property generated="never" lazy="false" name="active"/>
  <property generated="never" lazy="false" name="onlineTime"/>
  <property generated="never" lazy="false" name="mineNum"/>
  <property generated="never" lazy="false" name="breakNum"/>
  <property generated="never" lazy="false" name="placeNum"/>
  <property generated="never" lazy="false" name="killMonsterNum"/>
  <property generated="never" lazy="false" name="killAnimalNum"/>
  <property generated="never" lazy="false" name="killPlayerNum"/>
  <property generated="never" lazy="false" name="death"/>
  <property generated="never" lazy="false" name="power"/>
  <property generated="never" lazy="false" name="level"/>
  <property name="qq"/>
  <property generated="never" lazy="false" name="xq"/>
 </class>
 <class name="ServerTotalInfo" table="infos_servertotalinfo">
  <id name="id">
   <generator class="increment"/>
  </id>
  <property generated="never" lazy="false" name="startTime"/>
  <property generated="never" lazy="false" name="openTime"/>
  <property generated="never" lazy="false" name="totalJoinTimes"/>
  <property generated="never" lazy="false" name="totalOnlineTime"/>
  <property generated="never" lazy="false" name="maxOnline"/>
  <property generated="never" lazy="false" name="totalKills"/>
  <property generated="never" lazy="false" name="totalDeaths"/>
  <property generated="never" lazy="false" name="totalMines"/>
  <property generated="never" lazy="false" name="totalBreaks"/>
  <property generated="never" lazy="false" name="totalPlaces"/>
  <property generated="never" lazy="false" name="totalKillMonsters"/>
  <property generated="never" lazy="false" name="totalKillAnimals"/>
  <property generated="never" lazy="false" name="totalPlayers"/>
  <property generated="never" lazy="false" name="aliveAmounts"/>
  <property generated="never" lazy="false" name="activeAmounts"/>
 </class>
 <class name="GiftUser" table="giftuser">
  <id name="id">
   <generator class="increment"/>
  </id>
  <property generated="never" lazy="false" name="name"/>
  <property generated="never" lazy="false" name="giftHash" type="serializable"/>
 </class>
 <class name="JoinUser" table="joinuser">
  <id name="id">
   <generator class="increment"/>
  </id>
  <property generated="never" lazy="false" name="name"/>
  <property generated="never" lazy="false" name="free"/>
  <property generated="never" lazy="false" name="joinUser"/>
  <property generated="never" lazy="false" name="amount"/>
 </class>
</hibernate-mapping>
