<hibernate-mapping package="ad">
 <class name="AdUser" table="aduser">
  <id name="id">
   <generator class="increment"/>
  </id>
  <property generated="never" lazy="false" name="name"/>
  <property generated="never" lazy="false" name="msg"/>
  <property generated="never" lazy="false" name="price"/>
  <property generated="never" lazy="false" name="start"/>
 </class>
 <class name="AdChatUser" table="adchatuser">
  <id name="id">
   <generator class="increment"/>
  </id>
  <property generated="never" lazy="false" name="name"/>
  <property generated="never" lazy="false" name="cost"/>
  <property generated="never" lazy="false" length="50000" name="msg" type="serializable"/>
  <property name="count" not-null="true"/>
 </class>
</hibernate-mapping>
