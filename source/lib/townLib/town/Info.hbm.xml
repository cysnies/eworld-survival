<hibernate-mapping package="town">
 <class name="TownInfo" table="towninfo">
  <id name="id">
   <generator class="increment"/>
  </id>
  <property generated="never" lazy="false" name="landId"/>
  <property generated="never" lazy="false" name="name"/>
  <property name="level" not-null="true"/>
  <property name="exp" not-null="true"/>
  <property name="safeLock" not-null="true"/>
  <property generated="never" lazy="false" name="x"/>
  <property generated="never" lazy="false" name="z"/>
  <property generated="never" lazy="false" length="60000" name="userHash"/>
  <property length="60000" name="giveHash"/>
  <property generated="never" lazy="false" length="60000" name="askHash"/>
  <property generated="never" lazy="false" name="active"/>
 </class>
 <class name="TownUser" table="townuser">
  <id name="id">
   <generator class="increment"/>
  </id>
  <property generated="never" lazy="false" name="name"/>
  <property generated="never" lazy="false" name="townId"/>
  <property generated="never" lazy="false" name="pos"/>
 </class>
</hibernate-mapping>
