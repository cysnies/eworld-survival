<hibernate-mapping package="cus">
 <class name="MonPoint" table="monpoint">
  <id name="id">
   <generator class="increment"/>
  </id>
  <property column="pos_" generated="never" lazy="false" name="pos"/>
  <property column="type_" generated="never" lazy="false" name="type"/>
  <property name="monType"/>
  <property column="interval_" generated="never" lazy="false" name="interval"/>
  <property column="chance_" name="chance"/>
  <property column="max_" name="max"/>
  <property name="monList" type="serializable"/>
 </class>
</hibernate-mapping>
