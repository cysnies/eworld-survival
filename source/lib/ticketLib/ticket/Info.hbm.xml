<hibernate-mapping package="ticket">
 <class name="TicketUser" table="ticketuser">
  <id name="id">
   <generator class="identity"/>
  </id>
  <property generated="never" lazy="false" name="name"/>
  <property generated="never" lazy="false" name="ticket"/>
 </class>
 <class name="TicketLog" table="ticketlog">
  <id name="id">
   <generator class="identity"/>
  </id>
  <property generated="never" lazy="false" name="time"/>
  <property generated="never" lazy="false" name="log"/>
 </class>
 <class name="TicketCode" table="ticketcode">
  <id name="id">
   <generator class="identity"/>
  </id>
  <property name="code" unique="true"/>
  <property name="ticket"/>
  <property name="status"/>
  <property name="user"/>
  <property name="createTime"/>
  <property name="useTime"/>
 </class>
</hibernate-mapping>
