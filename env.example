# 容器内 survival 连接 MySQL
#
# 方式 A — 默认：复用 reference 已映射到宿主机的端口，**不需要**与 reference 共用 Docker 网络
#   MYSQL_HOST=host.docker.internal
#   MYSQL_PORT=<与 reference 的 MYSQL_PUBLISH_PORT 一致，默认 33060>
#   compose 中已有 extra_hosts: host.docker.internal → Linux 上必需
#
# 方式 B — 与 reference 栈中 mysql 容器在同一 bridge：直连服务名 mysql:3306（经 docker-compose 内部 DNS）
#   mysql_shared 网络见 docker-compose.yml 底部注释；然后：
#   MYSQL_HOST=mysql
#   MYSQL_PORT=3306
#   REFERENCE_STACK_NETWORK=reference_default   # docker-compose.yml 中 mysql_shared 的 external.name 会读此变量
#
# 若本目录启用了「独立 mysql」服务：MYSQL_HOST=mysql，MYSQL_PORT=3306
MYSQL_HOST=host.docker.internal
MYSQL_PORT=33060
# REFERENCE_STACK_NETWORK=reference_default
MYSQL_DATABASE=mc001
MYSQL_USER=mc001
MYSQL_PASSWORD=changeme
MYSQL_ROOT_PASSWORD=root

PUBLISH_PORT=25568
RCON_PUBLISH_PORT=25578
MC_SERVER_PORT=25565

# 已有的 MySQL 容器对外映射的 MySQL 端口（与 db.sh 默认连库对齐）
MYSQL_PUBLISH_PORT=33060

# db.sh：未启用本 compose 的 mysql 时，用 mysql:8.0 容器连库。若本机已装 mysql 可设 USE_LOCAL_MYSQL_CLI=1
# USE_LOCAL_MYSQL_CLI=0

# ./db.sh import 未指定文件时使用（示例）
# MIGRATION_SQL=sql/dumps/mc001_phpstudy_xxxxxx.sql
